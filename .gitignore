# .gitignore for XRStudio Unity project
# Based on github.com/github/gitignore/blob/main/Unity.gitignore

# ── Unity Generated Folders ─────────────────────────────
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log
/[Mm]emoryCaptures/
/[Rr]ecordings/

# ── IL2CPP / Android Artifacts ──────────────────────────
/[Ii][Ll]2[Cc]pp-*/
*.apk
*.aab
*.obb
/ExportedProject/

# ── Build Artifacts ─────────────────────────────────────
*.app
*.unitypackage
*.unitypackage.meta
*.stackdump

# ── Blend1 backup files ─────────────────────────────────
*.blend1
*.blend1.meta

# ── Asset Store / Auto-Generated ────────────────────────
/[Aa]ssets/[Aa]ssets[Ss]tore-*/
/[Aa]ssets/Plugins/Editor/JetBrains*

# ── IDE & OS Files ──────────────────────────────────────
.idea/
.vs/
.vscode/
.consulo/
*.suo
*.user
*.userprefs
*.DotSettings.user
*.csproj
*.sln
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini
.gradle/

# ── Compiled / Debug ────────────────────────────────────
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta
*.tmp
sysinfo.txt
mono_crash.*
crashlytics-build.properties

# ── Test Runner ─────────────────────────────────────────
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# ── Addressables ────────────────────────────────────────
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# ── Visual Scripting ────────────────────────────────────
/[Aa]ssets/Unity.VisualScripting.Generated/

# ── Items to keep ───────────────────────────────────────
# ALWAYS commit .meta files
!/[Aa]ssets/**/*.meta

# package version lock
!/[Pp]ackages/manifest.json

# package integrity
!/[Pp]ackages/packages-lock.json

# all project settings
!/[Pp]roject[Ss]ettings/**
